# Aether Environment Configuration Template
# ================================
#
# This file contains all environment variables used by the Aether application.
# Copy this file to .env and configure the values for your environment.
# Never commit .env to version control.

# ── Database ──────────────────────────────────────────────────────────────────────
# Database connection string
AETHER_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/aether

# ── Redis ─────────────────────────────────────────────────────────────
# Redis connection URL
AETHER_REDIS_URL=redis://localhost:6379/0

# ── JWT/Auth ──────────────────────────────────────────────────────
# Secret key for signing JWT tokens (REQUIRED - no default)
AETHER_JWT_SECRET_KEY=***
# JWT signing algorithm
AETHER_JWT_ALGORITHM=HS256
# Access token expiration in minutes
AETHER_ACCESS_TOKEN_EXPIRE_MINUTES=15
# Refresh token expiration in days
AETHER_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Magic Link ──────────────────────────────────────────────────
# Magic link expiration in minutes
AETHER_MAGIC_LINK_EXPIRE_MINUTES=15
# Frontend base URL for magic link generation
AETHER_FRONTEND_URL=http://localhost:3000

# ── Encryption ───────────────────────────────────────────────────────────────────────────────────────────────────────
# AES-256-GCM key (base64) for encrypting credentials at rest
AETHER_ENCRYPTION_KEY=***

# ── CORS ────────────────────────────────────────────────────────────────────────────────────────────────────────────────
# Comma-separated CORS origins
AETHER_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Environment ─────────────────────────────────────────────────
# Runtime environment (development, test, production)
AETHER_ENVIRONMENT=development

# ── AI / Local Model Driver ────────────────────────────────────
# Enable local llama.cpp driver on startup
AETHER_AI_LOCAL_DRIVER_ENABLED=true
# Base URL for local llama.cpp API
AETHER_AI_LOCAL_DRIVER_URL=http://localhost:8085
# Model ID for local driver registration
AETHER_AI_LOCAL_DRIVER_MODEL_ID=qwen3.6-35b-a3b

# ── Celery ─────────────────────────────────────────────────────
# Celery broker URL (defaults to REDIS_URL when empty)
AETHER_CELERY_BROKER_URL=
# Celery result backend (defaults to REDIS_URL when empty)
AETHER_CELERY_RESULT_BACKEND=

# ── Additional Variables from docker-compose.yml ──────────────────
# PostgreSQL configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=***
POSTGRES_DB=aether

# Redis configuration
REDIS_PASSWORD=***